// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TIMETABLE_SETTER
  CLASS_TEACHER
  NORMAL_TEACHER
  STUDENT
}

enum StudentClass {
  FE
  SE
  TE
  BE
}

enum ClassroomAccessStatus {
  REQUESTED
  APPROVED
  LOCK_PROOF_SUBMITTED
  LOCK_CONFIRMED
  LOCK_REJECTED
}

enum TimetablePlanStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum TimetableEntryType {
  THEORY
  LAB
}

model User {
  id                        String                   @id @default(cuid())
  username                  String                   @unique
  email                     String                   @unique
  notificationEmail         String?
  notificationEnabled       Boolean                  @default(true)
  mobNumber                 String                   @unique
  passwordHash              String
  role                      Role                     @default(STUDENT)
  // For STUDENT: which class they belong to
  studentClass              StudentClass?
  // For STUDENT: is this student a class representative?
  isCR                      Boolean                  @default(false)
  // For CLASS_TEACHER: which class are they the class teacher for?
  assignedClass             StudentClass?
  classroomRequests         ClassroomAccessRequest[] @relation("ClassroomRequestByStudent")
  reviewedClassroomRequests ClassroomAccessRequest[] @relation("ClassroomRequestByTeacher")
  createdTimetablePlans     TimetablePlan[]
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
}

model LabAllocation {
  id          String       @id @default(cuid())
  targetClass StudentClass
  subject     String
  labName     String
  day         String
  timeRange   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Enforce a lab cannot be double-booked
  @@unique([labName, day, timeRange], name: "lab_time_conflict")
  // Enforce a class cannot be double-booked
  @@unique([targetClass, day, timeRange], name: "class_time_conflict")
}

model ClassroomAccessRequest {
  id                   String                @id @default(cuid())
  requestedById        String
  classTeacherId       String
  studentClass         StudentClass
  classroomName        String
  requestedDate        DateTime
  requestedStartTime   String                @default("15:30")
  requestedEndTime     String                @default("18:30")
  purpose              String                @default("")
  status               ClassroomAccessStatus @default(REQUESTED)
  lockProofImageUrl    String?
  lockProofSubmittedAt DateTime?
  teacherRemarks       String?
  teacherConfirmedAt   DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  requestedBy  User @relation("ClassroomRequestByStudent", fields: [requestedById], references: [id])
  classTeacher User @relation("ClassroomRequestByTeacher", fields: [classTeacherId], references: [id])

  @@index([requestedById, status])
  @@index([classTeacherId, status])
}

model TimetablePlan {
  id                String              @id @default(cuid())
  title             String
  targetClass       StudentClass
  status            TimetablePlanStatus @default(DRAFT)
  effectiveFrom     DateTime?
  usedExtendedHours Boolean             @default(false)
  createdById       String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  createdBy    User                   @relation(fields: [createdById], references: [id])
  requirements TimetableRequirement[]
  entries      TimetableEntry[]

  @@index([targetClass, status, effectiveFrom])
  @@index([createdById, createdAt])
}

model TimetableRequirement {
  id          String   @id @default(cuid())
  planId      String
  subjectName String
  theoryHours Int      @default(0)
  labHours    Int      @default(0)
  createdAt   DateTime @default(now())

  plan TimetablePlan @relation(fields: [planId], references: [id])

  @@index([planId])
}

model TimetableEntry {
  id          String             @id @default(cuid())
  planId      String
  day         String
  startTime   String
  endTime     String
  slotIndex   Int
  subjectName String
  entryType   TimetableEntryType
  classroom   String?
  createdAt   DateTime           @default(now())

  plan TimetablePlan @relation(fields: [planId], references: [id])

  @@index([planId, day, slotIndex])
}
